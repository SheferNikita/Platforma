generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("EXTERNAL_DATABASE_URL")
}

model User {
  id                 String         @id @default(uuid())
  email              String         @unique
  password           String
  name               String
  role               UserRole       @default(STUDENT)
  isActive           Boolean        @default(true)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  adminLogs          AdminLog[]
  diaryReplies       Diary[]        @relation("DiaryReplies")
  notifications      Notification[]
  sessions           Session[]
  student            Student?
  studentNoteReplies StudentNote[]  @relation("StudentNoteReplies")
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Student {
  id              String            @id @default(uuid())
  userId          String            @unique
  phone           String?
  sobrietyDate    DateTime?
  notes           String?
  city            String?
  gender          String?
  age             Int?
  addictionType   String?
  surveyCompleted Boolean           @default(false)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  isClergy        Boolean?          @default(false)
  diaries         Diary[]
  enrollments     Enrollment[]
  progress        LessonProgress[]
  miniGroups      MiniGroupMember[]
  moduleAccess    ModuleAccess[]
  payments        Payment[]
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  studentNotes    StudentNote[]
}

model ModuleAccess {
  id        String    @id @default(uuid())
  studentId String
  moduleId  String
  expiresAt DateTime?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  module    Module    @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  student   Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, moduleId])
}

model AdminLog {
  id        String   @id @default(uuid())
  userId    String
  action    String
  entity    String
  entityId  String?
  details   Json?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Module {
  id          String          @id @default(uuid())
  title       String
  description String?
  order       Int             @default(0)
  isPublished Boolean         @default(false)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  lessons     Lesson[]
  access      ModuleAccess[]
  products    ProductModule[]
}

model Lesson {
  id          String             @id @default(uuid())
  moduleId    String
  title       String
  description String?
  content     String?
  duration    String?
  order       Int                @default(0)
  isPublished Boolean            @default(false)
  isTextOnly  Boolean            @default(false)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  publishAt   DateTime?
  diaries     Diary[]
  module      Module             @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  attachments LessonAttachment[]
  progress    LessonProgress[]
  videos      LessonVideo[]
  notes       StudentNote[]
}

model LessonVideo {
  id        String   @id @default(uuid())
  lessonId  String
  title     String?
  url       String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
}

model LessonAttachment {
  id           String   @id @default(uuid())
  lessonId     String
  filename     String
  originalName String
  mimeType     String
  size         Int
  url          String
  createdAt    DateTime @default(now())
  lesson       Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
}

model LessonProgress {
  id          String    @id @default(uuid())
  studentId   String
  lessonId    String
  isCompleted Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lesson      Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  student     Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, lessonId])
}

model Diary {
  id          String            @id @default(uuid())
  studentId   String
  lessonId    String
  content     String
  reply       String?
  repliedAt   DateTime?
  repliedById String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  lesson      Lesson            @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  repliedBy   User?             @relation("DiaryReplies", fields: [repliedById], references: [id])
  student     Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  attachments DiaryAttachment[]
}

model StudentNote {
  id          String            @id @default(uuid())
  studentId   String
  lessonId    String
  content     String
  noteType    String            @default("question")
  reply       String?
  repliedAt   DateTime?
  repliedById String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  lesson      Lesson            @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  repliedBy   User?             @relation("StudentNoteReplies", fields: [repliedById], references: [id])
  student     Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  attachments NoteAttachment[]
}

model DiaryAttachment {
  id           String   @id @default(uuid())
  diaryId      String
  filename     String
  originalName String
  mimeType     String
  size         Int
  data         String   @db.Text
  createdAt    DateTime @default(now())
  diary        Diary    @relation(fields: [diaryId], references: [id], onDelete: Cascade)
}

model NoteAttachment {
  id           String      @id @default(uuid())
  noteId       String
  filename     String
  originalName String
  mimeType     String
  size         Int
  data         String      @db.Text
  createdAt    DateTime    @default(now())
  note         StudentNote @relation(fields: [noteId], references: [id], onDelete: Cascade)
}

model LibraryItem {
  id          String   @id @default(uuid())
  title       String
  description String?
  type        String
  url         String?
  downloadUrl String?
  content     String?
  order       Int      @default(0)
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ScheduleEvent {
  id          String     @id @default(uuid())
  title       String
  description String?
  date        DateTime
  time        String?
  location    String?
  isOnline    Boolean    @default(false)
  link        String?
  miniGroupId String?
  isPublished Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  miniGroup   MiniGroup? @relation(fields: [miniGroupId], references: [id])
}

model Contact {
  id          String      @id @default(uuid())
  name        String
  role        String?
  phone       String?
  email       String?
  telegram    String?
  photo       String?
  order       Int         @default(0)
  isPublished Boolean     @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  miniGroups  MiniGroup[]
}

model Community {
  id          String   @id @default(uuid())
  name        String
  description String?
  address     String?
  city        String?
  phone       String?
  schedule    String?
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model MiniGroup {
  id          String            @id @default(uuid())
  title       String
  description String?
  chatLink    String?
  curatorId   String?
  isPublished Boolean           @default(false)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  curator     Contact?          @relation(fields: [curatorId], references: [id])
  members     MiniGroupMember[]
  events      ScheduleEvent[]
}

model MiniGroupMember {
  id          String    @id @default(uuid())
  miniGroupId String
  studentId   String
  joinedAt    DateTime  @default(now())
  miniGroup   MiniGroup @relation(fields: [miniGroupId], references: [id], onDelete: Cascade)
  student     Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([miniGroupId, studentId])
}

model Product {
  id                 String          @id @default(uuid())
  name               String
  description        String?
  price              Float
  currency           String          @default("RUB")
  accessDuration     Int?
  emailSubject       String?
  emailTemplate      String?
  isActive           Boolean         @default(true)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  accessDurationType String          @default("unlimited")
  accessExpiresAt    DateTime?
  offerUrl           String?
  enrollments        Enrollment[]
  orders             Order[]
  payments           Payment[]
  modules            ProductModule[]
}

model ProductModule {
  id        String   @id @default(uuid())
  productId String
  moduleId  String
  createdAt DateTime @default(now())
  module    Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, moduleId])
}

model Order {
  id             String      @id @default(uuid())
  firstName      String
  lastName       String
  phone          String
  email          String
  productId      String
  status         OrderStatus @default(NEW)
  amount         Float
  robokassaInvId Int?        @unique
  paidAt         DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  product        Product     @relation(fields: [productId], references: [id])
}

model Enrollment {
  id        String    @id @default(uuid())
  studentId String
  productId String
  expiresAt DateTime?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  product   Product   @relation(fields: [productId], references: [id])
  student   Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, productId])
}

model Payment {
  id             String        @id @default(uuid())
  studentId      String
  productId      String
  amount         Float
  currency       String        @default("RUB")
  status         PaymentStatus @default(PENDING)
  paymentMethod  String?
  robokassaInvId Int?          @unique
  robokassaData  Json?
  paidAt         DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  product        Product       @relation(fields: [productId], references: [id])
  student        Student       @relation(fields: [studentId], references: [id])
}

model EmailTemplate {
  id        String   @id @default(uuid())
  name      String   @unique
  subject   String
  body      String
  variables String[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EmailJob {
  id        String    @id @default(uuid())
  to        String
  subject   String
  body      String
  status    String    @default("pending")
  error     String?
  sentAt    DateTime?
  createdAt DateTime  @default(now())
}

model Setting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Metric {
  id        String   @id @default(uuid())
  type      String
  value     Float
  date      DateTime
  metadata  Json?
  createdAt DateTime @default(now())
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  CURATOR
  MENTOR
  PSYCHOLOGIST
  INTERN
  MODERATOR
  STUDENT
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum OrderStatus {
  NEW
  PAID
  CANCELLED
}

enum NotificationType {
  MENTOR_REPLY
  NEW_LESSON
  NEW_MODULE_ACCESS
  EVENT_REMINDER_24H
  EVENT_REMINDER_1H
  EVENT_CHANGED
  NEW_EVENT
  ACCESS_EXPIRES_14D
  ACCESS_EXPIRES_7D
  ACCESS_EXPIRES_1D
  ADDED_TO_GROUP
  MENTOR_CHANGED
  PROGRESS_25
  PROGRESS_50
  PROGRESS_75
  PROGRESS_100
  SOBRIETY_WEEK
  SOBRIETY_MONTH
  SOBRIETY_YEAR
  WELCOME
  NEW_LIBRARY_ITEM
  INCOMPLETE_LESSON
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  link      String?
  relatedId String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
}
