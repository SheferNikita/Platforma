generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = "postgresql://gen_user:9.U82o%7D%3Bs8BX7V@31.130.150.167:5432/Platform"
}

model AdminLog {
  id        String   @id
  userId    String
  action    String
  entity    String
  entityId  String?
  details   Json?
  createdAt DateTime @default(now())
  User      User     @relation(fields: [userId], references: [id])
}

model Community {
  id            String   @id
  name          String
  description   String?
  address       String?
  city          String?
  phone         String?
  schedule      String?
  isPublished   Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime
  format        String?  @default("offline") @db.VarChar(20)
  communityType String?  @default("mixed") @db.VarChar(30)
  dayOfWeek     String?  @db.VarChar(50)
  time          String?  @db.VarChar(20)
  leader        String?  @db.VarChar(255)
  leaderContact String?  @db.VarChar(255)
  link          String?  @db.VarChar(500)
}

model Contact {
  id          String      @id
  name        String
  role        String?
  phone       String?
  email       String?
  telegram    String?
  photo       String?
  order       Int         @default(0)
  isPublished Boolean     @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime
  MiniGroup   MiniGroup[]
}

model Diary {
  id              String            @id
  studentId       String
  lessonId        String
  content         String
  reply           String?
  repliedAt       DateTime?
  repliedById     String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime
  Lesson          Lesson            @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  User            User?             @relation(fields: [repliedById], references: [id])
  Student         Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  DiaryAttachment DiaryAttachment[]
}

model DiaryAttachment {
  id           String   @id
  diaryId      String
  filename     String
  originalName String
  mimeType     String
  size         Int
  data         String
  createdAt    DateTime @default(now())
  Diary        Diary    @relation(fields: [diaryId], references: [id], onDelete: Cascade)
}

model EmailJob {
  id        String    @id
  to        String
  subject   String
  body      String
  status    String    @default("pending")
  error     String?
  sentAt    DateTime?
  createdAt DateTime  @default(now())
}

model EmailTemplate {
  id          String   @id @default(uuid())
  key         String   @unique
  name        String
  subject     String
  body        String
  variables   String[]
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Enrollment {
  id        String    @id
  studentId String
  productId String
  expiresAt DateTime?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  Product   Product   @relation(fields: [productId], references: [id])
  Student   Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, productId])
}

model Lesson {
  id                 String             @id
  moduleId           String
  title              String
  description        String?
  content            String?
  duration           String?
  order              Int                @default(0)
  isPublished        Boolean            @default(false)
  isTextOnly         Boolean            @default(false)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime
  publishAt          DateTime?
  showDiary          Boolean            @default(true)
  showNotes          Boolean            @default(true)
  diaryDescription   String?            @default("Запишите свои мысли, эмоции и впечатления от пройденного урока")
  notesDescription   String?            @default("Запишите основные моменты урока, важные понятия и выводы")
  showTask           Boolean            @default(false)
  taskAllowedTariffs String[]           @default([])
  taskContent        String?
  Diary              Diary[]
  Module             Module             @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  LessonAttachment   LessonAttachment[]
  LessonProgress     LessonProgress[]
  LessonVideo        LessonVideo[]
  StudentNote        StudentNote[]
}

model LessonAttachment {
  id           String   @id
  lessonId     String
  filename     String
  originalName String
  mimeType     String
  size         Int
  url          String
  createdAt    DateTime @default(now())
  Lesson       Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
}

model LessonProgress {
  id          String    @id
  studentId   String
  lessonId    String
  isCompleted Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime
  Lesson      Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  Student     Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, lessonId])
}

model LessonVideo {
  id        String   @id
  lessonId  String
  title     String?
  url       String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  Lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
}

model LibraryItem {
  id             String   @id
  title          String
  description    String?
  type           String
  url            String?
  downloadUrl    String?
  content        String?
  order          Int      @default(0)
  isPublished    Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime
  allowedTariffs String[] @default([])
}

model Metric {
  id        String   @id
  type      String
  value     Float
  date      DateTime
  metadata  Json?
  createdAt DateTime @default(now())
}

model MiniGroup {
  id              String            @id
  title           String
  description     String?
  chatLink        String?
  curatorId       String?
  isPublished     Boolean           @default(false)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime
  Contact         Contact?          @relation(fields: [curatorId], references: [id])
  MiniGroupMember MiniGroupMember[]
  ScheduleEvent   ScheduleEvent[]
}

model MiniGroupMember {
  id          String    @id
  miniGroupId String
  studentId   String
  joinedAt    DateTime  @default(now())
  MiniGroup   MiniGroup @relation(fields: [miniGroupId], references: [id], onDelete: Cascade)
  Student     Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([miniGroupId, studentId])
}

model Module {
  id            String          @id
  title         String
  description   String?
  order         Int             @default(0)
  isPublished   Boolean         @default(false)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime
  Lesson        Lesson[]
  ModuleAccess  ModuleAccess[]
  ProductModule ProductModule[]
}

model ModuleAccess {
  id         String    @id
  studentId  String
  moduleId   String
  expiresAt  DateTime?
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime
  accessFrom DateTime?
  Module     Module    @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  Student    Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, moduleId])
}

model NoteAttachment {
  id           String      @id
  noteId       String
  filename     String
  originalName String
  mimeType     String
  size         Int
  data         String
  createdAt    DateTime    @default(now())
  StudentNote  StudentNote @relation(fields: [noteId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String           @id
  userId    String
  type      NotificationType
  title     String
  message   String
  link      String?
  relatedId String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  User      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, isRead])
}

model Order {
  id                 String               @id
  firstName          String
  lastName           String
  phone              String
  email              String
  productId          String
  status             OrderStatus          @default(NEW)
  amount             Float
  robokassaInvId     Int?                 @unique
  paidAt             DateTime?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime
  source             String?              @default("MANUAL") @db.VarChar(50)
  tildaTranId        String?              @db.VarChar(100)
  tildaOrderId       String?              @db.VarChar(100)
  utmSource          String?              @db.VarChar(255)
  utmMedium          String?              @db.VarChar(255)
  utmCampaign        String?              @db.VarChar(255)
  comment            String?
  Product            Product              @relation(fields: [productId], references: [id])
  OrderStatusHistory OrderStatusHistory[]
}

model OrderStatusHistory {
  id         String    @id @default(dbgenerated("(gen_random_uuid())::text")) @db.VarChar(36)
  orderId    String    @db.VarChar(36)
  fromStatus String?   @db.VarChar(50)
  toStatus   String    @db.VarChar(50)
  changedBy  String?   @db.VarChar(36)
  comment    String?
  createdAt  DateTime? @default(now()) @db.Timestamp(6)
  Order      Order     @relation(fields: [orderId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_order")

  @@index([orderId], map: "idx_order_status_history_order")
}

model Payment {
  id             String        @id
  studentId      String
  productId      String
  amount         Float
  currency       String        @default("RUB")
  status         PaymentStatus @default(PENDING)
  paymentMethod  String?
  robokassaInvId Int?          @unique
  robokassaData  Json?
  paidAt         DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime
  Product        Product       @relation(fields: [productId], references: [id])
  Student        Student       @relation(fields: [studentId], references: [id])
}

model Product {
  id                 String          @id
  name               String
  description        String?
  price              Float
  currency           String          @default("RUB")
  accessDuration     Int?
  emailSubject       String?
  emailTemplate      String?
  isActive           Boolean         @default(true)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime
  accessDurationType String          @default("unlimited")
  accessExpiresAt    DateTime?
  offerUrl           String?
  defaultTariff      StudentTariff?
  startDate          DateTime?
  Enrollment         Enrollment[]
  Order              Order[]
  Payment            Payment[]
  ProductModule      ProductModule[]
}

model ProductModule {
  id        String   @id
  productId String
  moduleId  String
  createdAt DateTime @default(now())
  Module    Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  Product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, moduleId])
}

model ScheduleEvent {
  id          String     @id
  title       String
  description String?
  date        DateTime
  time        String?
  location    String?
  isOnline    Boolean    @default(false)
  link        String?
  miniGroupId String?
  isPublished Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime
  MiniGroup   MiniGroup? @relation(fields: [miniGroupId], references: [id])
}

model Session {
  id        String   @id
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Setting {
  id        String   @id
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime
}

model Student {
  id                                        String            @id
  userId                                    String            @unique
  phone                                     String?
  sobrietyDate                              DateTime?
  notes                                     String?
  city                                      String?
  gender                                    String?
  age                                       Int?
  addictionType                             String?
  surveyCompleted                           Boolean           @default(false)
  createdAt                                 DateTime          @default(now())
  updatedAt                                 DateTime
  isClergy                                  Boolean?          @default(false)
  assignedPsychologistId                    String?
  tariff                                    StudentTariff     @default(WITH_MENTOR)
  Diary                                     Diary[]
  Enrollment                                Enrollment[]
  LessonProgress                            LessonProgress[]
  MiniGroupMember                           MiniGroupMember[]
  ModuleAccess                              ModuleAccess[]
  Payment                                   Payment[]
  User_Student_assignedPsychologistIdToUser User?             @relation("Student_assignedPsychologistIdToUser", fields: [assignedPsychologistId], references: [id])
  User_Student_userIdToUser                 User              @relation("Student_userIdToUser", fields: [userId], references: [id], onDelete: Cascade)
  StudentNote                               StudentNote[]
}

model StudentNote {
  id             String           @id
  studentId      String
  lessonId       String
  content        String
  noteType       String           @default("question")
  reply          String?
  repliedAt      DateTime?
  repliedById    String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime
  NoteAttachment NoteAttachment[]
  Lesson         Lesson           @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  User           User?            @relation(fields: [repliedById], references: [id])
  Student        Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model User {
  id                                           String                   @id
  email                                        String                   @unique
  password                                     String
  name                                         String
  role                                         UserRole                 @default(STUDENT)
  isActive                                     Boolean                  @default(true)
  createdAt                                    DateTime                 @default(now())
  updatedAt                                    DateTime
  AdminLog                                     AdminLog[]
  Diary                                        Diary[]
  Notification                                 Notification[]
  Session                                      Session[]
  Student_Student_assignedPsychologistIdToUser Student[]                @relation("Student_assignedPsychologistIdToUser")
  Student_Student_userIdToUser                 Student?                 @relation("Student_userIdToUser")
  StudentNote                                  StudentNote[]
  settingChanges                               PlatformSettingHistory[]
}

enum NotificationType {
  MENTOR_REPLY
  NEW_LESSON
  NEW_MODULE_ACCESS
  EVENT_REMINDER_24H
  EVENT_REMINDER_1H
  EVENT_CHANGED
  NEW_EVENT
  ACCESS_EXPIRES_14D
  ACCESS_EXPIRES_7D
  ACCESS_EXPIRES_1D
  ADDED_TO_GROUP
  MENTOR_CHANGED
  PROGRESS_25
  PROGRESS_50
  PROGRESS_75
  PROGRESS_100
  SOBRIETY_WEEK
  SOBRIETY_MONTH
  SOBRIETY_YEAR
  WELCOME
  NEW_LIBRARY_ITEM
  INCOMPLETE_LESSON
}

enum OrderStatus {
  NEW
  PAID
  CANCELLED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum StudentTariff {
  BASIC
  FAMILY
  WITH_MENTOR
  WITH_PSYCHOLOGIST
  INDIVIDUAL_PSYCHOLOGIST
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  CURATOR
  MENTOR
  PSYCHOLOGIST
  INTERN
  MODERATOR
  STUDENT
  PSYCHOLOGIST_GROUP
}

model PlatformSetting {
  id          String                   @id @default(uuid())
  key         String                   @unique
  value       String?
  label       String
  description String?
  category    String                   @default("general")
  type        String                   @default("text")
  isActive    Boolean                  @default(true)
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @default(now()) @updatedAt
  history     PlatformSettingHistory[]
}

model PlatformSettingHistory {
  id            String          @id @default(uuid())
  settingId     String
  previousValue String?
  newValue      String?
  changedById   String
  changeReason  String?
  createdAt     DateTime        @default(now())
  PlatformSetting PlatformSetting @relation(fields: [settingId], references: [id], onDelete: Cascade)
  User          User            @relation(fields: [changedById], references: [id], onDelete: Restrict)
}
