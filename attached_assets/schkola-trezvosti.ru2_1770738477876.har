            "size": 3250,
            "mimeType": "application/json",
            "text": "[{\"id\":\"b053ec1a-3c87-4fc0-936a-33713df1bd1b\",\"title\":\"Предобучение. \\\"Как решить проблемы, вызванные алкоголем или другими веществами\\\"\",\"description\":\"Здесь можно посмотреть записи вебинаров 2 -4 февраля.\",\"order\":1,\"isPublished\":true,\"createdAt\":\"2026-02-03T12:02:10.496Z\",\"updatedAt\":\"2026-02-05T13:43:41.499Z\",\"lessons\":[{\"id\":\"d685ce31-9e62-4705-a2b3-d8be9a4a75c5\",\"title\":\"\\\"Путь человека\\\". Запись вебинара от 2 февраля 2026 г. \",\"description\":\"Первый вебинар с диаконом Иоанном из серии вебинаров предобучения\",\"duration\":\"\",\"order\":1,\"isPublished\":true,\"publishAt\":null},{\"id\":\"87410f92-e33c-4c05-a91b-3517404b8493\",\"title\":\"\\\"Семь уровней зависимости и решение на каждом из них\\\". Запись вебинара от 3 февраля 2026 г.\",\"description\":\"Второй вебинар с диаконом Иоанном из серии вебинаров предобучения\",\"duration\":\"\",\"order\":3,\"isPublished\":true,\"publishAt\":null},{\"id\":\"272a8fa9-98e1-43da-a787-2d82fda72423\",\"title\":\"\\\"Трезвость как радость и любовь\\\". Запись вебинара от 4 февраля 2026 г.\",\"description\":\"Третий вебинар с диаконом Иоанном из серии вебинаров предобучения\",\"duration\":\"\",\"order\":4,\"isPublished\":true,\"publishAt\":null}],\"hasAccess\":true,\"accessExpiresAt\":null,\"accessFrom\":null},{\"id\":\"90c790cf-ad07-4fdc-8100-7a22f692c8a2\",\"title\":\"Вебинар с наркологом\",\"description\":\"\",\"order\":2,\"isPublished\":true,\"createdAt\":\"2026-02-05T13:43:20.349Z\",\"updatedAt\":\"2026-02-05T13:51:17.147Z\",\"lessons\":[{\"id\":\"1884e3fb-9d38-45cc-9fc0-1a9148fa297b\",\"title\":\"Наркологическая помощь на первом этапе становления в трезвой жизни\",\"description\":\"Василий Шуров - практикующий нарколог, психиатр-аддиктолог. \",\"duration\":\"\",\"order\":1,\"isPublished\":true,\"publishAt\":null}],\"hasAccess\":true,\"accessExpiresAt\":null,\"accessFrom\":null},{\"id\":\"322cfa08-4b1a-493e-a07c-2679d3c117bb\",\"title\":\"1 модуль. Решение на биологическом и психологическом уровнях\",\"description\":\"Сознательный выбор трезвости. Формирование навыка сохранения трезвости в любых обстоятельствах.\",\"order\":3,\"isPublished\":true,\"createdAt\":\"2026-02-03T17:14:49.695Z\",\"updatedAt\":\"2026-02-05T13:43:41.499Z\",\"lessons\":[{\"id\":\"cc3797e9-b764-4302-9d9f-78ef56bab34a\",\"title\":\"День 1. \\\"Единственная причина употребления алкоголя\\\"\",\"description\":\"\",\"duration\":\"\",\"order\":1,\"isPublished\":true,\"publishAt\":null},{\"id\":\"cd89461f-6be3-4c98-9afb-ab622ed35546\",\"title\":\"День 2. \\\"Открытия Г.А. Шичко\\\"\",\"description\":\"\",\"duration\":\"\",\"order\":4,\"isPublished\":true,\"publishAt\":null}],\"hasAccess\":true,\"accessExpiresAt\":null,\"accessFrom\":null}]"
