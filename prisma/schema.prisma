generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = "postgresql://gen_user:9.U82o%7D%3Bs8BX7V@31.130.150.167:5432/Platform"
}

model User {
  id                 String         @id @default(uuid())
  email              String         @unique
  password           String
  name               String
  role               UserRole       @default(STUDENT)
  isActive           Boolean        @default(true)
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  adminLogs          AdminLog[]
  diaryReplies       Diary[]        @relation("DiaryReplies")
  notifications      Notification[]
  sessions           Session[]
  assignedStudents   Student[]      @relation("AssignedPsychologist")
  student            Student?
  studentNoteReplies StudentNote[]  @relation("StudentNoteReplies")
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Student {
  id                     String            @id @default(uuid())
  userId                 String            @unique
  phone                  String?
  sobrietyDate           DateTime?
  notes                  String?
  city                   String?
  gender                 String?
  age                    Int?
  addictionType          String?
  surveyCompleted        Boolean           @default(false)
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt
  isClergy               Boolean?          @default(false)
  assignedPsychologistId String?
  tariff                 StudentTariff     @default(WITH_MENTOR)
  diaries                Diary[]
  enrollments            Enrollment[]
  progress               LessonProgress[]
  miniGroups             MiniGroupMember[]
  moduleAccess           ModuleAccess[]
  payments               Payment[]
  assignedPsychologist   User?             @relation("AssignedPsychologist", fields: [assignedPsychologistId], references: [id])
  user                   User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  studentNotes           StudentNote[]
}

model ModuleAccess {
  id         String    @id @default(uuid())
  studentId  String
  moduleId   String
  expiresAt  DateTime?
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  accessFrom DateTime?
  module     Module    @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  student    Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, moduleId])
}

model AdminLog {
  id        String   @id @default(uuid())
  userId    String
  action    String
  entity    String
  entityId  String?
  details   Json?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Module {
  id          String          @id @default(uuid())
  title       String
  description String?
  order       Int             @default(0)
  isPublished Boolean         @default(false)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  lessons     Lesson[]
  access      ModuleAccess[]
  products    ProductModule[]
}

model Lesson {
  id                  String             @id @default(uuid())
  moduleId            String
  title               String
  description         String?
  content             String?
  duration            String?
  order               Int                @default(0)
  isPublished         Boolean            @default(false)
  isTextOnly          Boolean            @default(false)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  publishAt           DateTime?
  showDiary           Boolean            @default(true)
  showNotes           Boolean            @default(true)
  diaryDescription    String?            @default("Запишите свои мысли, эмоции и впечатления от пройденного урока")
  notesDescription    String?            @default("Запишите основные моменты урока, важные понятия и выводы")
  showTask            Boolean            @default(false)
  taskContent         String?
  taskAllowedTariffs  String[]           @default([])
  diaries             Diary[]
  module              Module             @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  attachments         LessonAttachment[]
  progress            LessonProgress[]
  videos              LessonVideo[]
  notes               StudentNote[]
}

model LessonVideo {
  id        String   @id @default(uuid())
  lessonId  String
  title     String?
  url       String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
}

model LessonAttachment {
  id           String   @id @default(uuid())
  lessonId     String
  filename     String
  originalName String
  mimeType     String
  size         Int
  url          String
  createdAt    DateTime @default(now())
  lesson       Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
}

model LessonProgress {
  id          String    @id @default(uuid())
  studentId   String
  lessonId    String
  isCompleted Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lesson      Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  student     Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, lessonId])
}

model Diary {
  id          String            @id @default(uuid())
  studentId   String
  lessonId    String
  content     String
  reply       String?
  repliedAt   DateTime?
  repliedById String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  lesson      Lesson            @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  repliedBy   User?             @relation("DiaryReplies", fields: [repliedById], references: [id])
  student     Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  attachments DiaryAttachment[]
}

model StudentNote {
  id          String           @id @default(uuid())
  studentId   String
  lessonId    String
  content     String
  noteType    String           @default("question")
  reply       String?
  repliedAt   DateTime?
  repliedById String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  attachments NoteAttachment[]
  lesson      Lesson           @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  repliedBy   User?            @relation("StudentNoteReplies", fields: [repliedById], references: [id])
  student     Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model DiaryAttachment {
  id           String   @id @default(uuid())
  diaryId      String
  filename     String
  originalName String
  mimeType     String
  size         Int
  data         String
  createdAt    DateTime @default(now())
  diary        Diary    @relation(fields: [diaryId], references: [id], onDelete: Cascade)
}

model NoteAttachment {
  id           String      @id @default(uuid())
  noteId       String
  filename     String
  originalName String
  mimeType     String
  size         Int
  data         String
  createdAt    DateTime    @default(now())
  note         StudentNote @relation(fields: [noteId], references: [id], onDelete: Cascade)
}

model LibraryItem {
  id             String   @id @default(uuid())
  title          String
  description    String?
  type           String
  url            String?
  downloadUrl    String?
  content        String?
  order          Int      @default(0)
  isPublished    Boolean  @default(false)
  allowedTariffs String[] @default([])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model ScheduleEvent {
  id          String     @id @default(uuid())
  title       String
  description String?
  date        DateTime
  time        String?
  location    String?
  isOnline    Boolean    @default(false)
  link        String?
  miniGroupId String?
  isPublished Boolean    @default(false)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  miniGroup   MiniGroup? @relation(fields: [miniGroupId], references: [id])
}

model Contact {
  id          String      @id @default(uuid())
  name        String
  role        String?
  phone       String?
  email       String?
  telegram    String?
  photo       String?
  order       Int         @default(0)
  isPublished Boolean     @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  miniGroups  MiniGroup[]
}

model Community {
  id          String   @id @default(uuid())
  name        String
  description String?
  address     String?
  city        String?
  phone       String?
  schedule    String?
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model MiniGroup {
  id          String            @id @default(uuid())
  title       String
  description String?
  chatLink    String?
  curatorId   String?
  isPublished Boolean           @default(false)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  curator     Contact?          @relation(fields: [curatorId], references: [id])
  members     MiniGroupMember[]
  events      ScheduleEvent[]
}

model MiniGroupMember {
  id          String    @id @default(uuid())
  miniGroupId String
  studentId   String
  joinedAt    DateTime  @default(now())
  miniGroup   MiniGroup @relation(fields: [miniGroupId], references: [id], onDelete: Cascade)
  student     Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([miniGroupId, studentId])
}

model Product {
  id                 String          @id @default(uuid())
  name               String
  description        String?
  price              Float
  currency           String          @default("RUB")
  accessDuration     Int?
  emailSubject       String?
  emailTemplate      String?
  isActive           Boolean         @default(true)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  accessDurationType String          @default("unlimited")
  accessExpiresAt    DateTime?
  offerUrl           String?
  defaultTariff      StudentTariff?
  startDate          DateTime?
  enrollments        Enrollment[]
  orders             Order[]
  payments           Payment[]
  modules            ProductModule[]
}

model ProductModule {
  id        String   @id @default(uuid())
  productId String
  moduleId  String
  createdAt DateTime @default(now())
  module    Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, moduleId])
}

model Order {
  id                 String               @id @default(uuid())
  firstName          String
  lastName           String
  phone              String
  email              String
  productId          String
  status             OrderStatus          @default(NEW)
  amount             Float
  robokassaInvId     Int?                 @unique
  paidAt             DateTime?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  source             String?              @default("MANUAL") @db.VarChar(50)
  tildaTranId        String?              @db.VarChar(100)
  tildaOrderId       String?              @db.VarChar(100)
  utmSource          String?              @db.VarChar(255)
  utmMedium          String?              @db.VarChar(255)
  utmCampaign        String?              @db.VarChar(255)
  comment            String?
  product            Product              @relation(fields: [productId], references: [id])
  OrderStatusHistory OrderStatusHistory[]
}

model Enrollment {
  id        String    @id @default(uuid())
  studentId String
  productId String
  expiresAt DateTime?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  product   Product   @relation(fields: [productId], references: [id])
  student   Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, productId])
}

model Payment {
  id             String        @id @default(uuid())
  studentId      String
  productId      String
  amount         Float
  currency       String        @default("RUB")
  status         PaymentStatus @default(PENDING)
  paymentMethod  String?
  robokassaInvId Int?          @unique
  robokassaData  Json?
  paidAt         DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  product        Product       @relation(fields: [productId], references: [id])
  student        Student       @relation(fields: [studentId], references: [id])
}

model EmailTemplate {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  subject     String
  body        String   @db.Text
  description String?
  variables   String[]
  isEnabled   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model EmailJob {
  id        String    @id @default(uuid())
  to        String
  subject   String
  body      String
  status    String    @default("pending")
  error     String?
  sentAt    DateTime?
  createdAt DateTime  @default(now())
}

model Setting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Metric {
  id        String   @id @default(uuid())
  type      String
  value     Float
  date      DateTime
  metadata  Json?
  createdAt DateTime @default(now())
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  link      String?
  relatedId String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
}

model OrderStatusHistory {
  id         String    @id @default(dbgenerated("(gen_random_uuid())::text")) @db.VarChar(36)
  orderId    String    @db.VarChar(36)
  fromStatus String?   @db.VarChar(50)
  toStatus   String    @db.VarChar(50)
  changedBy  String?   @db.VarChar(36)
  comment    String?
  createdAt  DateTime? @default(now()) @db.Timestamp(6)
  Order      Order     @relation(fields: [orderId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_order")

  @@index([orderId], map: "idx_order_status_history_order")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  CURATOR
  MENTOR
  PSYCHOLOGIST
  INTERN
  MODERATOR
  ADMIN_ASSISTANT
  STUDENT
}

enum StudentTariff {
  BASIC
  FAMILY
  RELATIVE
  WITH_MENTOR
  WITH_PSYCHOLOGIST
  INDIVIDUAL_PSYCHOLOGIST
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum OrderStatus {
  NEW
  PAID
  CANCELLED
}

enum NotificationType {
  MENTOR_REPLY
  NEW_LESSON
  NEW_MODULE_ACCESS
  EVENT_REMINDER_24H
  EVENT_REMINDER_1H
  EVENT_CHANGED
  NEW_EVENT
  ACCESS_EXPIRES_14D
  ACCESS_EXPIRES_7D
  ACCESS_EXPIRES_1D
  ADDED_TO_GROUP
  MENTOR_CHANGED
  PROGRESS_25
  PROGRESS_50
  PROGRESS_75
  PROGRESS_100
  SOBRIETY_WEEK
  SOBRIETY_MONTH
  SOBRIETY_YEAR
  WELCOME
  NEW_LIBRARY_ITEM
  INCOMPLETE_LESSON
}

model PlatformSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String?  @db.Text
  label     String
  category  String
  type      SettingType @default(TEXT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  history   PlatformSettingHistory[]
}

model PlatformSettingHistory {
  id        String   @id @default(uuid())
  settingId String
  oldValue  String?  @db.Text
  newValue  String?  @db.Text
  changedBy String
  changedAt DateTime @default(now())
  setting   PlatformSetting @relation(fields: [settingId], references: [id], onDelete: Cascade)
}

enum SettingType {
  TEXT
  TEXTAREA
  URL
  FILE
  IMAGE
  AUDIO
}
